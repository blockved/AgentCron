{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash docs/harness/linters/invariant-check.sh 2>&1 | head -50"
          },
          {
            "type": "command",
            "command": "bash docs/harness/linters/spec-sync-check.sh 2>&1 | head -50"
          }
        ]
      }
    ]
  }
}
